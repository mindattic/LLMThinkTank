#!/bin/bash
# Pre-commit hook: runs all unit tests before allowing a commit.
# If any test fails, the commit is blocked.

echo "Running unit tests..."
dotnet test LLMThinkTank.UnitTests --verbosity minimal --no-restore 2>&1

if [ $? -ne 0 ]; then
    echo ""
    echo "COMMIT BLOCKED: Unit tests failed. Fix failing tests before committing."
    exit 1
fi

echo "All tests passed."
exit 0
