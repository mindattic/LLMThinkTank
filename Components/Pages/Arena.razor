@page "/thinktank"
@inject LlmThinkTankService ThinkTankService
@inject SettingsService Settings
@inject ChatConversationsService Conversations
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>LLM Think Tank</PageTitle>

<div class="thinktank-container">

    <header class="thinktank-header">
        <h1>LLM <span class="accent">Think Tank</span></h1>
        <p class="subtitle">Siloed conversations per tab. Humans only choose the prompt and the participants.</p>
    </header>

    <div class="chat-tabs">
        @foreach (var c in Conversations.Conversations)
        {
            <button class="chat-tab @(Conversations.ActiveConversation?.ChatId == c.ChatId ? "active" : "")"
                    @onclick="(() => Conversations.SetActive(c.ChatId))">
                <span class="chat-tab-title">@c.Title</span>
                <span class="chat-tab-id">@c.ChatId[..Math.Min(6, c.ChatId.Length)]</span>
                <span class="chat-tab-close" title="Close" @onclick:stopPropagation @onclick="(() => CloseTab(c.ChatId))">×</span>
            </button>
        }
        <button class="chat-tab add" @onclick="NewTab">+ New</button>
    </div>

    @if (Active is null)
    {
        <div class="setup-panel">
            <p>No conversation tabs yet.</p>
            <button class="start-btn" @onclick="NewTab">Create a conversation</button>
        </div>
    }
    else
    {
        <div class="setup-panel">
            <label>Discussion prompt</label>
            <textarea value="@Active.Topic" @oninput="OnTopicInput" rows="3" placeholder="e.g. Is consciousness computational?" />

            <div class="participants">
                <label>Participants</label>
                <div class="participant-grid">
                    @foreach (var t in Settings.Templates)
                    {
                        var selected = Active.Participants.Any(p => p.TemplateId == t.TemplateId);
                        <button class="participant-pill @(selected ? "selected" : "")" @onclick="(() => ToggleParticipant(t))">
                            <span class="pill-avatar">@GetProviderAvatar(t.ProviderId)</span>
                            <span>@t.DisplayName</span>
                        </button>
                    }
                </div>
            </div>

            @if (!string.IsNullOrEmpty(ActiveState.Error))
            {
                <div class="error-msg">@ActiveState.Error</div>
            }

            <button class="start-btn" @onclick="ToggleRun">
                @(ActiveState.Running ? "Stop" : "Start")
            </button>
        </div>

        <div class="conversation-wrap">
            <div class="scoreboard">
                @foreach (var p in Active.Participants)
                {
                    <div class="score-card @p.ProviderId @(ActiveState.CurrentSpeaker == p.ParticipantId ? "speaking" : "")">
                        <span class="score-avatar">@GetProviderAvatar(p.ProviderId)</span>
                        <span class="score-name">@p.DisplayName</span>
                        @if (ActiveState.CurrentSpeaker == p.ParticipantId)
                        {
                            <span class="thinking-dot">●</span>
                        }
                    </div>
                }
            </div>

            <div class="conversation-grid">
                <aside class="member-list" aria-label="Members">
                    <div class="member-list-header">Members (@Active.Participants.Count)</div>
                    <div class="member-list-items">
                        @foreach (var p in Active.Participants)
                        {
                            <div class="member-item @(ActiveState.CurrentSpeaker == p.ParticipantId ? "active" : "")">
                                <span class="member-avatar">@GetProviderAvatar(p.ProviderId)</span>
                                <span class="member-name">@p.DisplayName</span>
                            </div>
                        }
                    </div>
                </aside>

                <div class="messages" @ref="_messagesDiv" @onscroll="OnMessagesScrolled">
                    @foreach (var msg in ActiveState.Messages)
                    {
                        var p = Active.Participants.FirstOrDefault(x => x.ParticipantId == msg.ParticipantId);
                        <div class="message-bubble @(p?.ProviderId ?? "") @(msg.IsError ? "error-bubble" : "")">
                            <div class="bubble-header">
                                <span class="bubble-avatar">@GetProviderAvatar(p?.ProviderId ?? "")</span>
                                <span class="bubble-name">@(p?.DisplayName ?? msg.ParticipantId)</span>
                                <span class="bubble-round">Round @msg.Round</span>
                            </div>
                            <div class="bubble-text">@msg.Text</div>
                        </div>
                    }

                    @if (ActiveState.Running && ActiveState.CurrentSpeaker is not null)
                    {
                        var p = Active.Participants.FirstOrDefault(x => x.ParticipantId == ActiveState.CurrentSpeaker);
                        <div class="typing-indicator @(p?.ProviderId ?? "")">
                            <span class="bubble-avatar">@GetProviderAvatar(p?.ProviderId ?? "")</span>
                            <span class="bubble-name">@(p?.DisplayName ?? "")</span>
                            <span class="typing-dots"><span>.</span><span>.</span><span>.</span></span>
                        </div>
                    }
                </div>
            </div>

            @if (!ActiveState.Running && ActiveState.Messages.Count > 0)
            {
                <div class="done-bar">
                    <span>Conversation complete — @ActiveState.Messages.Count messages exchanged.</span>
                </div>
            }

        </div>

        <div class="status-log">
            <div class="status-log-header">
                <span>Status log</span>
                <span class="status-log-tabs">
                    <button class="status-log-tab @(_activeStatusTab == StatusTab.Perspective ? "active" : "")" @onclick="(() => _activeStatusTab = StatusTab.Perspective)">Perspective</button>
                    <button class="status-log-tab @(_activeStatusTab == StatusTab.Diagnostics ? "active" : "")" @onclick="(() => _activeStatusTab = StatusTab.Diagnostics)">Diagnostics</button>
                </span>
            </div>
            <div class="status-log-items">
                @if (_activeStatusTab == StatusTab.Perspective)
                {
                    @if (ActiveState.StatusEvents.Count == 0)
                    {
                        <div class="status-log-empty">No status events yet.</div>
                    }
                    else
                    {
                        @foreach (var e in ActiveState.StatusEvents)
                        {
                            <div class="status-log-item">
                                <span class="status-ts">@e.Timestamp.LocalDateTime.ToString("HH:mm:ss")</span>
                                <span class="status-text">@e.Text</span>
                            </div>
                        }
                    }
                }
                else
                {
                    @if (ActiveState.Diagnostics.Count == 0)
                    {
                        <div class="status-log-empty">No diagnostics yet.</div>
                    }
                    else
                    {
                        @foreach (var e in ActiveState.Diagnostics)
                        {
                            <div class="status-log-item">
                                <span class="status-ts">@e.Timestamp.LocalDateTime.ToString("HH:mm:ss")</span>
                                <span class="status-text">@e.Text</span>
                            </div>
                        }
                    }
                }
            </div>
        </div>
    }
</div>

@code {
    private enum StatusTab { Perspective, Diagnostics }
    private StatusTab _activeStatusTab = StatusTab.Perspective;
    private ChatConversation? Active => Conversations.ActiveConversation;
    private ConversationUiState ActiveState => GetState(Active);

    private readonly Dictionary<string, ConversationUiState> _states = new();

    private ElementReference _messagesDiv;
    private bool _followConversation = true;
    private int _lastRenderedMessageCount;

    protected override void OnInitialized()
    {
        Conversations.Changed += OnConversationsChanged;
        ThinkTankService.Diagnostics += OnDiagnostics;
        RestoreFromConversationState();
        _ = RestoreAllAsync();
        if (Conversations.Conversations.Count == 0)
            NewTab();
    }

    private void OnDiagnostics(string providerId, string raw, bool isError)
    {
        if (Active is null)
            return;

        var ts = DateTimeOffset.UtcNow;
        var prefix = isError ? $"{providerId.ToUpperInvariant()} ERROR" : $"{providerId.ToUpperInvariant()} OK";
        var text = $"{prefix}: {raw}";
        if (text.Length > 4000)
            text = text[..4000] + "…";

        var e = new SettingsService.PersistedStatusEvent(ts, text);
        Active.Diagnostics.Add(e);
        ActiveState.Diagnostics.Add(new StatusEvent(e.Timestamp, e.Text));
        Conversations.NotifyChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        var count = ActiveState.Messages.Count;
        if (count != _lastRenderedMessageCount)
        {
            _lastRenderedMessageCount = count;
            if (_followConversation)
                await JS.InvokeVoidAsync("LLMThinkTank.scrollToBottom", _messagesDiv);
        }
    }

    private void RestoreFromConversationState()
    {
        foreach (var c in Conversations.Conversations)
        {
            var state = GetState(c);
            state.Messages.Clear();
            foreach (var m in c.Messages)
            {
                state.Messages.Add(new ConversationUiMessage
                {
                    ParticipantId = m.ParticipantId,
                    Text = m.Text,
                    Round = m.Round,
                    IsError = m.IsError
                });
            }

            state.StatusEvents.Clear();
            foreach (var e in c.StatusEvents)
                state.StatusEvents.Add(new StatusEvent(e.Timestamp, e.Text));

            state.Diagnostics.Clear();
            foreach (var e in c.Diagnostics)
                state.Diagnostics.Add(new StatusEvent(e.Timestamp, e.Text));
        }
    }

    private async Task RestoreAllAsync()
    {
        foreach (var c in Conversations.Conversations)
        {
            try
            {
                var turns = await ChatStorage.LoadTurnsAsync(c.ChatId);
                if (turns.Count == 0)
                    continue;

                var state = GetState(c);
                state.Messages.Clear();
                c.Messages.Clear();
                foreach (var t in turns)
                {
                    var msg = new ConversationUiMessage
                    {
                        ParticipantId = t.ParticipantId,
                        Text = t.Text,
                        Round = t.Round,
                        IsError = t.IsError
                    };

                    state.Messages.Add(msg);
                    c.Messages.Add(new SettingsService.PersistedMessage(msg.ParticipantId, msg.Text, msg.Round, msg.IsError));
                }

                Conversations.NotifyChanged();
            }
            catch { }
        }

        await InvokeAsync(StateHasChanged);
    }

    private void OnConversationsChanged() => InvokeAsync(StateHasChanged);

    private async Task OnMessagesScrolled()
    {
        _followConversation = await JS.InvokeAsync<bool>("LLMThinkTank.isNearBottom", _messagesDiv, 60);
    }

    private ConversationUiState GetState(ChatConversation? c)
    {
        if (c is null)
            return new ConversationUiState();

        if (!_states.TryGetValue(c.ChatId, out var state))
        {
            state = new ConversationUiState();
            _states[c.ChatId] = state;
        }
        return state;
    }

    private void NewTab()
    {
        var convo = Conversations.CreateConversation($"Chat {Conversations.Conversations.Count + 1}");
        // No default participants; user selects 2+ personalities per conversation.
    }

    private void CloseTab(string chatId)
    {
        Conversations.CloseConversation(chatId);
        _states.Remove(chatId);
    }

    private void ToggleParticipant(ParticipantTemplate t)
    {
        if (Active is null)
            return;

        var existing = Active.Participants.FirstOrDefault(p => p.TemplateId == t.TemplateId);
        if (existing is not null)
            Active.Participants.Remove(existing);
        else
            AddParticipant(Active, t);

        Conversations.NotifyChanged();
    }

    private void AddParticipant(ChatConversation convo, ParticipantTemplate t)
    {
        convo.Participants.Add(new ChatParticipant(
            ParticipantId: ChatConversationsService.NewId(),
            TemplateId: t.TemplateId,
            ProviderId: t.ProviderId,
            DisplayName: t.DisplayName,
            PersonalityMarkdown: t.PersonalityMarkdown,
            CustomInstructions: t.CustomInstructions,
            AuthOverrideJson: t.AuthOverrideJson));
    }

    private void OnTopicInput(ChangeEventArgs e)
    {
        if (Active is null)
            return;

        Active.Topic = e.Value?.ToString() ?? "";
        Conversations.NotifyChanged();
    }

    private string GetProviderAvatar(string providerId)
        => ThinkTankService.Models.FirstOrDefault(m => m.Id == providerId)?.Avatar ?? "?";

    private async Task StartActive()
    {
        if (Active is null)
            return;

        var state = ActiveState;
        state.Error = null;

        if (string.IsNullOrWhiteSpace(Active.Topic)) { state.Error = "Please enter a discussion prompt."; return; }
        if (Active.Participants.Count < 2) { state.Error = "Pick at least 2 participants."; return; }

        state.Running = true;
        state.StopRequested = false;
        state.Messages.Clear();
        state.CompletedTurns = 0;
        state.TotalTurns = 0;

        var sharedHistory = new List<SharedTurn>();
        Conversations.NotifyChanged();
        await ChatStorage.AppendChatJsonAsync(Active.ChatId, new { type = "chat-start", chatId = Active.ChatId, topic = Active.Topic, ts = DateTimeOffset.UtcNow });

        var round = 0;
        while (!state.StopRequested)
        {
            round++;
            foreach (var p in Active.Participants)
            {
                if (state.StopRequested)
                    break;

                state.CurrentSpeaker = p.ParticipantId;
                StateHasChanged();
                await Task.Delay(50);

                try
                {
                    var personality = string.IsNullOrWhiteSpace(p.CustomInstructions)
                        ? p.PersonalityMarkdown
                        : $"{p.PersonalityMarkdown}\n\n# Custom instructions\n\n{p.CustomInstructions}";

                    var response = await ThinkTankService.CallProvider(p.ProviderId, personality, p.AuthOverrideJson, Active.Topic!, sharedHistory);

                    sharedHistory.Add(new SharedTurn
                    {
                        ModelId = p.ParticipantId,
                        ModelName = p.DisplayName,
                        Text = response,
                        Round = round
                    });

                    state.Messages.Add(new ConversationUiMessage
                    {
                        ParticipantId = p.ParticipantId,
                        Text = response,
                        Round = round
                    });

                    Active.Messages.Add(new SettingsService.PersistedMessage(p.ParticipantId, response, round, false));

                    await ChatStorage.AppendChatJsonAsync(Active.ChatId, new
                    {
                        type = "turn",
                        chatId = Active.ChatId,
                        participantId = p.ParticipantId,
                        templateId = p.TemplateId,
                        providerId = p.ProviderId,
                        displayName = p.DisplayName,
                        round,
                        text = response,
                        ts = DateTimeOffset.UtcNow
                    });

                    await ChatStorage.WritePerspectiveAsync(Active.ChatId, p.ParticipantId,
                        $"# Perspective\n\n- ChatId: `{Active.ChatId}`\n- ParticipantId: `{p.ParticipantId}`\n- DisplayName: `{p.DisplayName}`\n- Provider: `{p.ProviderId}`\n\n## Personality\n\n{p.PersonalityMarkdown}\n\n## Latest\n\nRound {round}: {response}\n");

                    // Stub "status events" to show cross-participant observations.
                    // Later this should be generated by each participant updating its own perspective and emitting diffs.
                    state.StatusEvents.Add(new StatusEvent(DateTimeOffset.UtcNow, $"{p.DisplayName} updated their perspective for this chat."));
                    Active.StatusEvents.Add(new SettingsService.PersistedStatusEvent(DateTimeOffset.UtcNow, $"{p.DisplayName} updated their perspective for this chat."));
                    Conversations.NotifyChanged();
                }
                catch (Exception ex)
                {
                    state.Messages.Add(new ConversationUiMessage
                    {
                        ParticipantId = p.ParticipantId,
                        Text = $"[Error: {ex.Message}]",
                        Round = round,
                        IsError = true
                    });

                    Active.Messages.Add(new SettingsService.PersistedMessage(p.ParticipantId, $"[Error: {ex.Message}]", round, true));
                    Conversations.NotifyChanged();
                }

                state.CompletedTurns++;
                state.CurrentSpeaker = null;
                StateHasChanged();
                await Task.Delay(400);
            }
        }

        state.Running = false;
        state.CurrentSpeaker = null;
        StateHasChanged();
    }

    private async Task ToggleRun()
    {
        if (Active is null)
            return;

        if (ActiveState.Running)
        {
            ActiveState.StopRequested = true;
            return;
        }

        await StartActive();
    }

    public void Dispose()
    {
        Conversations.Changed -= OnConversationsChanged;
        ThinkTankService.Diagnostics -= OnDiagnostics;
    }

    private class ConversationUiMessage
    {
        public string ParticipantId { get; set; } = "";
        public string Text { get; set; } = "";
        public int Round { get; set; }
        public bool IsError { get; set; }
    }

    private class ConversationUiState
    {
        public string Topic { get; set; } = "";
        public bool Running { get; set; }
        public bool StopRequested { get; set; }
        public string? CurrentSpeaker { get; set; }
        public string? Error { get; set; }
        public int TotalTurns { get; set; }
        public int CompletedTurns { get; set; }
        public double ProgressPct => TotalTurns == 0 ? 0 : (CompletedTurns / (double)TotalTurns) * 100;
        public List<ConversationUiMessage> Messages { get; } = new();
        public List<StatusEvent> StatusEvents { get; } = new();
        public List<StatusEvent> Diagnostics { get; } = new();
    }

    private record StatusEvent(DateTimeOffset Timestamp, string Text);
}
