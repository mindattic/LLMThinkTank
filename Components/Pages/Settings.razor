@page "/settings"
@namespace LLMThinkTank.Components.Pages
@inject SettingsService ThinkTankSettings
@inject LlmThinkTankService ThinkTank
@inject ChatLogService Chat
@inject HumanNameService HumanNames
@inject NameGeneratorService NameGen
@implements IDisposable

<PageTitle>Settings</PageTitle>

<div class="settings-container">
    <header class="thinktank-header">
        <h1>Settings</h1>
        <p class="subtitle">Configure providers and run connectivity tests.</p>
    </header>

    <div class="settings-grid">
        <div class="settings-panel">
            <div class="settings-tabs">
                <button class="settings-tab @(_activeSection == SettingsSection.Models ? "active" : "")" @onclick="(() => _activeSection = SettingsSection.Models)">
                    Providers
                </button>
                <button class="settings-tab @(_activeSection == SettingsSection.Providers ? "active" : "")" @onclick="(() => _activeSection = SettingsSection.Providers)">
                    Personalities
                </button>
                <button class="settings-tab @(_activeSection == SettingsSection.Appearance ? "active" : "")" @onclick="(() => _activeSection = SettingsSection.Appearance)">
                    Appearance
                </button>
            </div>

            @if (_activeSection == SettingsSection.Appearance)
            {
                <SettingsAppearance />
            }
            else if (_activeSection == SettingsSection.Models)
            {
                <div class="templates-split">
                    <div class="templates-left">
                        <div class="templates-left-header">
                            <span>Providers</span>
                        </div>
                        <div class="templates-left-list">
                            @foreach (var p in _providerOptions)
                            {
                                <button class="settings-tab template-row @(p.Id == _activeProviderId ? "active" : "")" @onclick="(() => SelectProvider(p.Id))">
                                    <span class="settings-tab-avatar">
                                        @GetProviderAvatar(p.Id)
                                        <span class="provider-dot @GetProviderDotClass(p.Id)" title="@GetProviderDotTitle(p.Id)"></span>
                                    </span>
                                    <span class="template-name">@p.Name</span>
                                </button>
                            }
                        </div>
                    </div>

                    <div class="templates-right settings-form">
                        <label>Auth config (JSON)</label>
                        <textarea class="settings-textarea" @bind="ProviderAuthJson" @bind:event="oninput" rows="12" placeholder="Enter your API key here..."></textarea>

                        <label>Known models</label>
                        <div class="model-chip-row">
                            @foreach (var m in GetKnownModels(_activeProviderId))
                            {
                                <button type="button" class="model-chip" @onclick="(() => SetProviderModel(m))">@m</button>
                            }
                        </div>

                        <div class="settings-row">
                            <button class="start-btn" @onclick="SaveProviderAuth">Save</button>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="templates-split">
                    <div class="templates-left">
                        <div class="templates-left-header">
                            <span>Personalities</span>
                            <div class="add-dropdown">
                                <button class="settings-tab" @onclick="ToggleAddDropdown">+ Add</button>
                                @if (_showAddDropdown)
                                {
                                    <div class="add-dropdown-menu">
                                        @foreach (var p in _providerOptions)
                                        {
                                            <button class="add-dropdown-item" @onclick="(() => AddTemplateForProvider(p.Id))">
                                                <span>@GetProviderAvatar(p.Id)</span> @p.Name
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="templates-left-list">
                            @foreach (var t in ThinkTankSettings.Templates)
                            {
                                <button class="settings-tab template-row @(t.TemplateId == _activeTemplateId ? "active" : "")" @onclick="(() => SelectTemplate(t.TemplateId))">
                                    <span class="settings-tab-avatar">@GetProviderAvatar(t.ProviderId)</span>
                                    <span class="template-name">@t.DisplayName</span>
                                </button>
                            }
                        </div>
                    </div>

                    <div class="templates-right settings-form">
                        @if (_activeTemplate is not null)
                        {
                            <label>Display name</label>
                            <input value="@_activeTemplate.DisplayName" @oninput="OnTemplateNameChanged" placeholder="e.g. Bob Claude" />

                            <label>Provider</label>
                            <select value="@_activeTemplate.ProviderId" @onchange="OnTemplateProviderChanged">
                                @foreach (var p in _providerOptions)
                                {
                                    <option value="@p.Id">@p.Name</option>
                                }
                            </select>

                            @* Custom Auth Config - hidden for now, will add later
                            <label>Custom Auth Config (JSON, optional)</label>
                            <textarea class="settings-textarea" @oninput="OnTemplateAuthOverrideChanged" rows="6">@(_activeTemplate.AuthOverrideJson ?? "")</textarea>
                            *@

                            <label>Personality (markdown)</label>
                            <textarea class="settings-textarea" @oninput="OnTemplatePersonalityChanged" rows="16">@_activeTemplate.PersonalityMarkdown</textarea>

                            <div class="settings-row" style="justify-content:flex-end;">
                                <button class="start-btn" @onclick="GeneratePersonality" disabled="@_generating">@(_generating ? "Generating…" : "Generate")</button>
                            </div>

                            <div class="settings-row">
                                <button class="start-btn" @onclick="SaveActiveTemplate" disabled="@(_activeTemplate is null)">Save</button>
                                <button class="start-btn" @onclick="TestTemplate" disabled="@_testing">Test connection</button>
                                <button class="reset-btn" @onclick="RemoveTemplate" disabled="@(ThinkTankSettings.Templates.Count <= 1)">Remove</button>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(_lastError))
                            {
                                <div class="error-msg">@_lastError</div>
                            }
                        }
                    </div>
                </div>
            }
        </div>


    </div>
</div>

@code {
    private enum SettingsSection { Models, Providers, Appearance }

    private string? _activeTemplateId;
    private bool _showAddDropdown;
    private string _activeProviderId = "openai";
    private string _providerAuthJson = "";
    private string ProviderAuthJson
    {
        get => _providerAuthJson;
        set
        {
            _providerAuthJson = value ?? "";
            DebouncePersistProviderAuth(_activeProviderId, _providerAuthJson);
            DebounceAuthConnectivityCheck(_activeProviderId, _providerAuthJson);
        }
    }
    private SettingsSection _activeSection = SettingsSection.Providers;
    private bool _testing;
    private string? _lastError;
    private bool _generating;
    private CancellationTokenSource? _templatePersistDebounceCts;

    private readonly Dictionary<string, ProviderStatus> _providerStatus = new();
    private CancellationTokenSource? _authDebounceCts;
    private CancellationTokenSource? _persistDebounceCts;
    private PeriodicTimer? _providerPollTimer;

    private ParticipantTemplate? _activeTemplate => _activeTemplateId is null
        ? null
        : ThinkTankSettings.Templates.FirstOrDefault(t => t.TemplateId == _activeTemplateId);

    private readonly List<(string Id, string Name)> _providerOptions = new()
    {
        ("openai", "ChatGPT"),
        ("claude", "Claude"),
        ("gemini", "Gemini"),
        ("deepseek", "DeepSeek")
    };

    private static readonly Dictionary<string, string[]> KnownModels = new()
    {
        ["openai"] = ["gpt-4", "gpt-5", "gpt-5-mini", "gpt-5-nano"],
        ["claude"] = ["claude-sonnet-4", "claude-sonnet-4-6"],
        ["gemini"] = ["gemini-2.5-flash", "gemini-2.5-pro", "gemini-2.0-flash", "gemini-2.0-flash-lite"],
        ["deepseek"] = ["deepseek-chat", "deepseek-reasoner"]
    };

    protected override void OnInitialized()
    {
        Chat.Changed += OnChatChanged;

        _activeTemplateId ??= ThinkTankSettings.Templates.FirstOrDefault()?.TemplateId;
        if (string.IsNullOrWhiteSpace(_activeProviderId))
            _activeProviderId = "openai";

        _providerAuthJson = ThinkTankSettings.GetAuthJson(_activeProviderId);

        foreach (var p in _providerOptions)
            _providerStatus[p.Id] = new ProviderStatus(ProviderOnlineState.Unknown);

        _providerPollTimer = new PeriodicTimer(TimeSpan.FromSeconds(10));
        _ = ProviderPollLoopAsync();
    }

    private void DebouncePersistProviderAuth(string providerId, string authJson)
    {
        _persistDebounceCts?.Cancel();
        _persistDebounceCts?.Dispose();
        _persistDebounceCts = new CancellationTokenSource();

        var token = _persistDebounceCts.Token;
        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(TimeSpan.FromSeconds(1.25), token);
                if (token.IsCancellationRequested)
                    return;

                ThinkTankSettings.SetAuthJson(providerId, authJson ?? "{}");
            }
            catch (OperationCanceledException) { }
        }, token);
    }

    private IEnumerable<string> GetKnownModels(string providerId)
        => KnownModels.TryGetValue(providerId, out var models) ? models : Array.Empty<string>();

    private void SetProviderModel(string model)
    {
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(_providerAuthJson ?? "{}");
            var type = doc.RootElement.TryGetProperty("type", out var t) ? t.GetString() : null;
            var apiKey = doc.RootElement.TryGetProperty("apiKey", out var k) ? k.GetString() : null;

            if (string.IsNullOrWhiteSpace(type))
                type = _activeProviderId is "openai" or "deepseek" ? "bearer" : _activeProviderId;

            ProviderAuthJson = $"{{\n  \"type\": \"{type}\",\n  \"apiKey\": \"{apiKey ?? ""}\",\n  \"model\": \"{model}\"\n}}";
        }
        catch
        {
            ProviderAuthJson = $"{{\n  \"type\": \"{_activeProviderId}\",\n  \"apiKey\": \"\",\n  \"model\": \"{model}\"\n}}";
        }
    }

    private async Task ProviderPollLoopAsync()
    {
        if (_providerPollTimer is null)
            return;

        while (await _providerPollTimer.WaitForNextTickAsync())
        {
            foreach (var p in _providerOptions)
                _ = CheckProviderOnlineAsync(p.Id, ThinkTankSettings.GetAuthJson(p.Id));
        }
    }

    private void OnChatChanged() => InvokeAsync(StateHasChanged);

    private void SelectTemplate(string templateId)
    {
        SaveActiveTemplate();
        _activeTemplateId = templateId;
        _lastError = null;
    }

    private string GetProviderAvatar(string providerId)
        => ThinkTank.Models.FirstOrDefault(m => m.Id == providerId)?.Avatar ?? "?";

    private string GetProviderDotClass(string providerId)
        => _providerStatus.TryGetValue(providerId, out var s)
            ? s.State switch
            {
                ProviderOnlineState.Online => "online",
                ProviderOnlineState.Offline => "offline",
                ProviderOnlineState.Checking => "checking",
                _ => "unknown"
            }
            : "unknown";

    private string GetProviderDotTitle(string providerId)
        => _providerStatus.TryGetValue(providerId, out var s)
            ? s.State switch
            {
                ProviderOnlineState.Online => "Online",
                ProviderOnlineState.Offline => string.IsNullOrWhiteSpace(s.LastError) ? "Offline" : $"Offline: {s.LastError}",
                ProviderOnlineState.Checking => "Checking...",
                _ => "Unknown"
            }
            : "Unknown";

    private void SelectProvider(string providerId)
    {
        SaveActiveTemplate();
        _activeProviderId = providerId;
        _providerAuthJson = ThinkTankSettings.GetAuthJson(providerId);
        _lastError = null;

        _ = CheckProviderOnlineAsync(_activeProviderId, _providerAuthJson);
    }

    private void DebounceAuthConnectivityCheck(string providerId, string authJson)
    {
        _authDebounceCts?.Cancel();
        _authDebounceCts?.Dispose();
        _authDebounceCts = new CancellationTokenSource();

        var token = _authDebounceCts.Token;
        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(TimeSpan.FromSeconds(2), token);
                if (token.IsCancellationRequested)
                    return;

                await InvokeAsync(async () => await CheckProviderOnlineAsync(providerId, authJson));
            }
            catch (OperationCanceledException) { }
        }, token);
    }

    private async Task CheckProviderOnlineAsync(string providerId, string authJson)
    {
        if (!_providerStatus.TryGetValue(providerId, out _))
            _providerStatus[providerId] = new ProviderStatus(ProviderOnlineState.Unknown);

        _providerStatus[providerId] = _providerStatus[providerId] with { State = ProviderOnlineState.Checking, LastChecked = DateTimeOffset.UtcNow, LastError = null };
        StateHasChanged();

        try
        {
            var response = await ThinkTank.CallProvider(
                providerId,
                personalityMarkdown: "You are a connectivity test. Reply with 'OK'.",
                authOverrideJson: authJson,
                topic: "Connectivity test: reply with OK.",
                history: new List<SharedTurn>());

            _providerStatus[providerId] = _providerStatus[providerId] with { State = ProviderOnlineState.Online, LastChecked = DateTimeOffset.UtcNow, LastError = null };
        }
        catch (Exception ex)
        {
            _providerStatus[providerId] = _providerStatus[providerId] with { State = ProviderOnlineState.Offline, LastChecked = DateTimeOffset.UtcNow, LastError = ex.Message };
        }

        StateHasChanged();
    }

    private void SaveProviderAuth()
    {
        ThinkTankSettings.SetAuthJson(_activeProviderId, _providerAuthJson ?? "{}");
        _lastError = null;
        Chat.Add("Models", $"Saved auth config for {_activeProviderId}.");
    }

    private void ToggleAddDropdown()
    {
        _showAddDropdown = !_showAddDropdown;
    }

    private async Task AddTemplateForProvider(string providerId)
    {
        _showAddDropdown = false;
        var llmName = _providerOptions.FirstOrDefault(p => p.Id == providerId).Name;
        var firstName = HumanNames.NextFirstName();
        var fallbackPersonality = $"# {firstName} ({llmName})\n\n- Voice: curious and concise\n- Values: clarity, honesty\n- Habits: asks follow-up questions\n- Biases: may over-generalize\n";

        var template = new ParticipantTemplate(
            TemplateId: ChatConversationsService.NewId(),
            ProviderId: providerId,
            DisplayName: $"{firstName} ({llmName})",
            PersonalityMarkdown: fallbackPersonality,
            AuthOverrideJson: null);

        ThinkTankSettings.Templates.Add(template);
        ThinkTankSettings.SaveTemplates(ThinkTankSettings.Templates);
        _activeTemplateId = template.TemplateId;
        _lastError = null;
        StateHasChanged();

        // Try to generate a richer personality in the background
        try
        {
            var personality = await GenerateStarterPersonality(providerId, firstName, llmName);
            if (personality != fallbackPersonality)
            {
                var idx = ThinkTankSettings.Templates.FindIndex(t => t.TemplateId == template.TemplateId);
                if (idx >= 0)
                {
                    ThinkTankSettings.Templates[idx] = template with { PersonalityMarkdown = personality };
                    ThinkTankSettings.SaveTemplates(ThinkTankSettings.Templates);
                    StateHasChanged();
                }
            }
        }
        catch { /* fallback personality already set */ }
    }

    private async Task<string> GenerateStarterPersonality(string providerId, string firstName, string llmName)
    {
        var prompt = $"Create a short personality profile for a chat participant named {firstName}. " +
                     "Output markdown only. Include: 1) Voice/style, 2) Values, 3) Conversational habits, 4) Biases to watch for. Keep it under 150 words.";

        try
        {
            return await ThinkTank.CallProvider(providerId, "You create short markdown personality profiles.", authOverrideJson: null, topic: prompt, history: new List<SharedTurn>());
        }
        catch
        {
            return $"# {firstName} ({llmName})\n\n- Voice: curious and concise\n- Values: clarity, honesty\n- Habits: asks follow-up questions\n- Biases: may over-generalize\n";
        }
    }

    private void RemoveTemplate()
    {
        if (_activeTemplate is null)
            return;

        var idx = ThinkTankSettings.Templates.FindIndex(t => t.TemplateId == _activeTemplate.TemplateId);
        ThinkTankSettings.Templates.RemoveAll(t => t.TemplateId == _activeTemplate.TemplateId);
        ThinkTankSettings.SaveTemplates(ThinkTankSettings.Templates);

        if (ThinkTankSettings.Templates.Count == 0)
        {
            _activeTemplateId = null;
            return;
        }

        var nextIdx = Math.Clamp(idx, 0, ThinkTankSettings.Templates.Count - 1);
        _activeTemplateId = ThinkTankSettings.Templates[nextIdx].TemplateId;
        _lastError = null;
    }

    private void UpdateActiveTemplate(Func<ParticipantTemplate, ParticipantTemplate> update)
    {
        if (_activeTemplate is null)
            return;

        var idx = ThinkTankSettings.Templates.FindIndex(t => t.TemplateId == _activeTemplate.TemplateId);
        if (idx < 0)
            return;

        ThinkTankSettings.Templates[idx] = update(ThinkTankSettings.Templates[idx]);
        DebouncePersistTemplates();
    }

    private void DebouncePersistTemplates()
    {
        _templatePersistDebounceCts?.Cancel();
        _templatePersistDebounceCts?.Dispose();
        _templatePersistDebounceCts = new CancellationTokenSource();

        var token = _templatePersistDebounceCts.Token;
        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(TimeSpan.FromMilliseconds(650), token);
                if (token.IsCancellationRequested)
                    return;

                await InvokeAsync(() => ThinkTankSettings.SaveTemplates(ThinkTankSettings.Templates));
            }
            catch (OperationCanceledException) { }
        }, token);
    }

    private void SaveActiveTemplate()
    {
        if (_activeTemplate is null)
            return;

        ThinkTankSettings.SaveTemplates(ThinkTankSettings.Templates);
    }

    private async Task GeneratePersonality()
    {
        _lastError = null;
        if (_activeTemplate is null)
            return;

        _generating = true;
        try
        {
            var prompt = $"Create a detailed markdown personality profile for a chat participant named {_activeTemplate.DisplayName}. " +
                         "Include: voice/style, beliefs, thoughts, biases, rules, and failure modes to avoid. " +
                         "Keep it under 250 words. Output markdown only.";

            var md = await ThinkTank.CallProvider(
                _activeTemplate.ProviderId,
                personalityMarkdown: "You generate personality profiles for simulated participants.",
                authOverrideJson: _activeTemplate.AuthOverrideJson,
                topic: prompt,
                history: new List<SharedTurn>());

            UpdateActiveTemplate(t => t with { PersonalityMarkdown = md });
            SaveActiveTemplate();
        }
        catch (Exception ex)
        {
            _lastError = ex.Message;
        }
        finally
        {
            _generating = false;
        }
    }

    private void OnTemplateNameChanged(ChangeEventArgs e)
        => UpdateActiveTemplate(t => t with { DisplayName = e.Value?.ToString() ?? "" });

    private void OnTemplateProviderChanged(ChangeEventArgs e)
    {
        var providerId = e.Value?.ToString() ?? "openai";
        var providerName = _providerOptions.FirstOrDefault(p => p.Id == providerId).Name ?? providerId;

        UpdateActiveTemplate(t =>
        {
            var firstName = t.DisplayName;
            var idx = firstName.IndexOf(" (", StringComparison.Ordinal);
            if (idx > 0)
                firstName = firstName[..idx];

            return t with { ProviderId = providerId, DisplayName = $"{firstName} ({providerName})" };
        });
    }

    private void OnTemplatePersonalityChanged(ChangeEventArgs e)
        => UpdateActiveTemplate(t => t with { PersonalityMarkdown = e.Value?.ToString() ?? "" });

    private void OnTemplateAuthOverrideChanged(ChangeEventArgs e)
    {
        var v = e.Value?.ToString();
        UpdateActiveTemplate(t => t with { AuthOverrideJson = string.IsNullOrWhiteSpace(v) ? null : v });
    }


    private async Task TestTemplate()
    {
        _lastError = null;

        if (_activeTemplate is null)
            return;

        var effectiveKey = ThinkTankSettings.GetKeyForProvider(_activeTemplate.ProviderId, null);
        if (string.IsNullOrWhiteSpace(effectiveKey))
        {
            _lastError = "API key is required. Please check your provider settings.";
            return;
        }

        var chatId = ChatConversationsService.NewId();
        var prompt = "Connectivity test: reply with a single short sentence confirming you can respond.";

        _testing = true;
        Chat.Add(_activeTemplate.DisplayName, $"[TEST {chatId}] Sending: {prompt}");

        try
        {
            var response = await ThinkTank.CallProvider(_activeTemplate.ProviderId, _activeTemplate.PersonalityMarkdown, _activeTemplate.AuthOverrideJson, prompt, history: new List<SharedTurn>());
            Chat.Add(_activeTemplate.DisplayName, $"[TEST {chatId}] Response: {response}");

            await ChatStorage.AppendChatJsonAsync(chatId, new
            {
                id = chatId,
                type = "settings-test",
                participantTemplateId = _activeTemplate.TemplateId,
                providerId = _activeTemplate.ProviderId,
                displayName = _activeTemplate.DisplayName,
                prompt,
                response,
                ts = DateTimeOffset.UtcNow
            });

            await ChatStorage.WritePerspectiveAsync(chatId, _activeTemplate.ProviderId,
                $"# Provider test\n\n- ChatId: `{chatId}`\n- TemplateId: `{_activeTemplate.TemplateId}`\n- Provider: `{_activeTemplate.ProviderId}`\n- DisplayName: `{_activeTemplate.DisplayName}`\n- When: `{DateTimeOffset.UtcNow:o}`\n\n## Notes\n\nThis is a connectivity test run from Settings.\n");
        }
        catch (Exception ex)
        {
            Chat.Add(_activeTemplate.DisplayName, $"[TEST {chatId}] Error: {ex.Message}", isError: true);
            _lastError = ex.Message;
        }
        finally
        {
            _testing = false;
        }
    }

    public void Dispose()
    {
        Chat.Changed -= OnChatChanged;

        _authDebounceCts?.Cancel();
        _authDebounceCts?.Dispose();
        _persistDebounceCts?.Cancel();
        _persistDebounceCts?.Dispose();
        _templatePersistDebounceCts?.Cancel();
        _templatePersistDebounceCts?.Dispose();
        _providerPollTimer?.Dispose();
    }

    private enum ProviderOnlineState { Unknown, Checking, Online, Offline }

    private sealed record ProviderStatus(ProviderOnlineState State)
    {
        public DateTimeOffset? LastChecked { get; init; }
        public string? LastError { get; init; }
    }
}
