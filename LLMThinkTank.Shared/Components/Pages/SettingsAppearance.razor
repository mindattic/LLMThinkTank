@namespace LLMThinkTank.Shared.Components.Pages
@inject AppearanceService Appearance
@inject IJSRuntime JS

<div class="settings-form">
    <label>Theme</label>

    <select class="settings-select" value="@GetThemeValue(Appearance.Mode)" @onchange="OnThemeChanged">
        @foreach (var t in Themes)
        {
            <option value="@t.Value">@t.Label</option>
        }
    </select>

    <label>Control Height — @(Appearance.ControlHeight)px</label>
    <input type="range" min="28" max="60" step="2"
           value="@Appearance.ControlHeight"
           @oninput="OnControlHeightChanged"
           class="settings-range" />

    <label>Gutter — @(Appearance.Gutter)px</label>
    <input type="range" min="0" max="30" step="2"
           value="@Appearance.Gutter"
           @oninput="OnGutterChanged"
           class="settings-range" />

    <label>Border Radius — @(Appearance.BorderRadius)px</label>
    <input type="range" min="0" max="24" step="2"
           value="@Appearance.BorderRadius"
           @oninput="OnBorderRadiusChanged"
           class="settings-range" />
</div>

@code {
    private record ThemeItem(AppearanceMode Mode, string Value, string Label);

    private static readonly ThemeItem[] Themes =
    [
        new(AppearanceMode.Dark, "dark", "Dark"),
        new(AppearanceMode.Light, "light", "Light"),
        new(AppearanceMode.Spring, "spring", "Spring"),
        new(AppearanceMode.Summer, "summer", "Summer"),
        new(AppearanceMode.Autumn, "autumn", "Autumn"),
        new(AppearanceMode.Winter, "winter", "Winter"),
        new(AppearanceMode.Matrix, "matrix", "Matrix"),
        new(AppearanceMode.Ice, "ice", "Ice"),
        new(AppearanceMode.Sunset, "sunset", "Sunset"),
        new(AppearanceMode.Neon, "neon", "Neon"),
        new(AppearanceMode.Dracula, "dracula", "Dracula"),
        new(AppearanceMode.Solarized, "solarized", "Solarized"),
        new(AppearanceMode.Midnight, "midnight", "Midnight"),
        new(AppearanceMode.Aurora, "aurora", "Aurora"),
        new(AppearanceMode.Ember, "ember", "Ember"),
        new(AppearanceMode.Ocean, "ocean", "Ocean"),
        new(AppearanceMode.Forest, "forest", "Forest"),
        new(AppearanceMode.Mono, "mono", "Mono"),
    ];

    private static string GetThemeValue(AppearanceMode mode)
        => Themes.FirstOrDefault(t => t.Mode == mode)?.Value ?? "dark";

    private async Task OnThemeChanged(ChangeEventArgs e)
    {
        var value = (e.Value?.ToString() ?? "dark").Trim().ToLowerInvariant();
        var mode = Themes.FirstOrDefault(t => t.Value == value)?.Mode ?? AppearanceMode.Dark;
        await Set(mode);
    }

    private async Task OnControlHeightChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var px))
        {
            Appearance.SetControlHeight(px);
            await JS.InvokeVoidAsync("LLMThinkTank.setControlHeight", px);
        }
    }

    private async Task OnGutterChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var px))
        {
            Appearance.SetGutter(px);
            await JS.InvokeVoidAsync("LLMThinkTank.setGutter", px);
        }
    }

    private async Task OnBorderRadiusChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var px))
        {
            Appearance.SetBorderRadius(px);
            await JS.InvokeVoidAsync("LLMThinkTank.setBorderRadius", px);
        }
    }

    private async Task Set(AppearanceMode mode)
    {
        Appearance.SetMode(mode);
        await JS.InvokeVoidAsync("LLMThinkTank.setTheme", GetThemeValue(mode));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await JS.InvokeVoidAsync("LLMThinkTank.setTheme", GetThemeValue(Appearance.Mode));
        await JS.InvokeVoidAsync("LLMThinkTank.setControlHeight", Appearance.ControlHeight);
        await JS.InvokeVoidAsync("LLMThinkTank.setGutter", Appearance.Gutter);
        await JS.InvokeVoidAsync("LLMThinkTank.setBorderRadius", Appearance.BorderRadius);
    }
}
